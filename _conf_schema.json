{
  "enabled_groups": {
    "description": "启用的QQ群列表",
    "type": "list",
    "hint": "配置可以触发表情包的QQ群号列表，为空则对所有群生效",
    "default": [],
    "items": {
      "type": "string"
    }
  },
  "window_size": {
    "description": "滑动窗口大小",
    "type": "int",
    "default": 30,
    "hint": "记录多少条群消息用于语境分析",
    "slider": {
      "min": 10,
      "max": 100,
      "step": 5
    }
  },
  "trigger_interval": {
    "description": "触发间隔（消息数）",
    "type": "int",
    "default": 5,
    "hint": "每收到多少条消息进行一次概率判断",
    "slider": {
      "min": 1,
      "max": 20,
      "step": 1
    }
  },
  "trigger_probability": {
    "description": "触发概率",
    "type": "int",
    "default": 50,
    "hint": "满足触发条件时发送表情包的概率，范围为1-100",
    "slider": {
      "min": 1,
      "max": 100,
      "step": 10
    }
  },
  "use_llm_analysis": {
    "description": "使用LLM分析语境",
    "type": "bool",
    "default": true,
    "hint": "开启后，将使用LLM分析群聊语境来选择表情包；关闭则使用关键词匹配"
  },
  "convert_static_to_gif": {
    "description": "静态图转GIF发送",
    "type": "bool",
    "default": false,
    "hint": "开启后，发送静态图片表情时会将其转换为1帧的GIF格式"
  }
}
