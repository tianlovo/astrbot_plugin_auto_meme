{
  "basic": {
    "description": "基础配置",
    "type": "object",
    "items": {
      "enabled_groups": {
        "description": "启用的QQ群列表",
        "type": "list",
        "hint": "配置可以触发表情包的QQ群号列表，为空则对所有群生效",
        "default": [],
        "items": {
          "type": "string"
        }
      },
      "window_size": {
        "description": "滑动窗口大小",
        "type": "int",
        "default": 30,
        "hint": "记录多少条群消息用于语境分析",
        "slider": {
          "min": 10,
          "max": 100,
          "step": 5
        }
      },
      "trigger_interval": {
        "description": "触发间隔（消息数）",
        "type": "int",
        "default": 5,
        "hint": "每收到多少条消息进行一次概率判断",
        "slider": {
          "min": 1,
          "max": 20,
          "step": 1
        }
      },
      "trigger_probability": {
        "description": "触发概率",
        "type": "int",
        "default": 50,
        "hint": "满足触发条件时发送表情包的概率，范围为1-100",
        "slider": {
          "min": 1,
          "max": 100,
          "step": 10
        }
      },
      "convert_static_to_gif": {
        "description": "静态图转GIF发送",
        "type": "bool",
        "default": false,
        "hint": "开启后，发送静态图片表情时会将其转换为1帧的GIF格式"
      }
    }
  },
  "llm_analysis": {
    "description": "LLM语境分析配置",
    "type": "object",
    "items": {
      "use_llm_analysis": {
        "description": "使用LLM分析语境",
        "type": "bool",
        "default": true,
        "hint": "开启后，将使用LLM分析群聊语境来选择表情包；关闭则使用关键词匹配"
      },
      "llm_system_prompt": {
        "description": "系统提示词",
        "type": "string",
        "default": "你是一个专业的群聊语境分析助手。请根据提供的群聊消息历史，分析当前对话的氛围和情绪，选择最合适的表情包类别。\\n\\n可用的表情包类别及其使用场景：\\n{emotions_list}\\n\\n重要：请仅返回类别名称，不要有任何解释或额外内容。如果无法确定，请返回 \"random\"。",
        "hint": "自定义LLM分析语境时的系统提示词。留空则使用默认提示词。可用变量：{emotions_list} 表示可用表情包类别列表"
      },
      "llm_user_prompt": {
        "description": "用户提示词",
        "type": "string",
        "default": "请分析以下群聊消息，选择最合适的表情包类别：\\n\\n{context_text}\\n\\n最合适的类别是：",
        "hint": "自定义LLM分析语境时的用户提示词。留空则使用默认提示词。可用变量：{context_text} 表示群聊消息内容"
      }
    }
  },
  "webui": {
    "description": "WebUI管理后台配置",
    "type": "object",
    "items": {
      "webui_port": {
        "description": "WebUI 端口",
        "type": "int",
        "default": 5000,
        "hint": "表情包管理后台的端口号，修改后需要重启插件生效",
        "slider": {
          "min": 1000,
          "max": 65535,
          "step": 1
        }
      },
      "webui_key": {
        "description": "WebUI 登录密钥",
        "type": "string",
        "default": "meme_auto",
        "hint": "管理后台的登录密钥，建议修改默认值以增强安全性"
      }
    }
  }
}
